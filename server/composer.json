{
    "name": "arcane/skill-swap-server",
    "description": "SkillSwap backend - Slim 4 + PHP 8.3",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "slim/slim": "^4.14",
        "slim/psr7": "^1.8",
        "php-di/php-di": "^7.0",
        "firebase/php-jwt": "^6.4",
        "vlucas/phpdotenv": "^5.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": ["src/", "./"]
        }
    },
    "scripts": {
        "start": "php -S localhost:8080 -t public public/index.php"
    }
}